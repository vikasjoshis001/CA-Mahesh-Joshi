# Email Service
# Get your API key from https://resend.com/signup (free tier: 100 emails/day)
RESEND_API_KEY=your_resend_api_key_here

# Google Places API — for live Google Reviews on the homepage
# 1. Create a project at https://console.cloud.google.com
# 2. Enable "Places API (New)" (NOT the legacy Places API)
# 3. Create an API key and restrict it to the Places API
# 4. Find your Place ID at: https://developers.google.com/maps/documentation/places/web-service/place-id
#    (search for "Mahesh Joshi & Associates, Wakad")
# NOTE: Do NOT prefix with NEXT_PUBLIC_ — this key must stay server-side only
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GOOGLE_PLACE_ID=your_google_place_id_here

# Bundle Analysis (optional)
# Set to 'true' to analyze bundle size with: npm run analyze
ANALYZE=false
